# Добавьте эти переменные в ваш .env файл

# Auth (обязательно)
# Better Auth рекомендует использовать BETTER_AUTH_SECRET и BETTER_AUTH_URL
# Сгенерируйте секрет командой: openssl rand -base64 32
BETTER_AUTH_SECRET=your_secret_here_min_32_chars
BETTER_AUTH_URL=http://localhost:3000

# Для обратной совместимости (можно удалить после миграции на BETTER_AUTH_SECRET)
AUTH_SECRET=your_secret_here

# Webhook Service
WEBHOOKS_PORT=3001

# Extension API (REST API для браузерного расширения HH)
EXTENSION_API_PORT=3002

# YooKassa (ЮКасса)
YOOKASSA_SHOP_ID=your_shop_id
YOOKASSA_SECRET_KEY=your_secret_key
YOOKASSA_API_URL=https://api.yookassa.ru/v3

# PostHog Analytics
NEXT_PUBLIC_POSTHOG_KEY=your_posthog_project_api_key
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# AI Proxy (для обхода блокировок)
NEXT_PUBLIC_AI_PROXY_URL=http://localhost:3002

# Документация
NEXT_PUBLIC_DOCS_URL=https://docs.hh.qbs.ru
