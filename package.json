{
  "name": "@qbs-autonaim/root",
  "private": true,
  "engines": {
    "node": "^22.21.0",
    "bun": "1.3.9"
  },
  "scripts": {
    "build": "turbo run build",
    "build:changed": "turbo run build --filter=...[HEAD^1]",
    "build:app": "turbo run build --filter=@qbs-autonaim/app...",
    "build:web": "turbo run build --filter=@qbs-autonaim/web...",
    "build:tg": "turbo run build --filter=@qbs-autonaim/tg-client...",
    "build:jobs": "turbo run build --filter=@qbs-autonaim/jobs...",
    "build:clean": "bun run clean:build && bun run build",
    "clean": "git clean -xdf node_modules",
    "clean:workspaces": "turbo run clean",
    "clean:build": "powershell -ExecutionPolicy Bypass -File scripts/clean-build.ps1",
    "auth:generate": "bun --filter @qbs-autonaim/auth generate",
    "db:push": "turbo -F @qbs-autonaim/db push",
    "db:studio": "turbo -F @qbs-autonaim/db studio",
    "db:generate-key": "bun --filter @qbs-autonaim/db generate-key",
    "dev": "turbo watch dev --continue",
    "dev:app": "turbo watch dev -F @qbs-autonaim/app...",
    "dev:jobs": "turbo watch dev -F @qbs-autonaim/jobs...",
    "dev:webhooks": "turbo watch dev -F @qbs-autonaim/webhooks",
    "dev:interview": "turbo watch dev -F @qbs-autonaim/interview -F @qbs-autonaim/interview-server",
    "dev:extension-api": "turbo watch dev -F @qbs-autonaim/extension-api",
    "dev:all": "concurrently \"bun run tg:dev\" \"bun run jobs:dev\" \"bun run dev:webhooks\"",
    "jobs:dev": "bun --filter @qbs-autonaim/jobs --filter @qbs-autonaim/jobs-parsers dev",
    "tg": "bun --filter @qbs-autonaim/tg-client start",
    "tg:dev": "bun --filter @qbs-autonaim/tg-client start:dev",
    "format": "biome format .",
    "format:fix": "biome format --write .",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "lint:ws": "bunx sherif@latest",
    "test": "turbo run test --env-mode=loose",
    "typecheck": "turbo run typecheck",
    "ui-add": "turbo run ui-add",
    "deps:update": "bunx npm-check-updates -u \"apps/*/package.json\" \"packages/*/package.json\" && bun install",
    "knip": "cross-env CI=true POSTGRES_URL=postgresql://postgres:postgres@localhost/qbs-dev knip",
    "check:client-imports": "node scripts/check-client-imports.mjs",
    "arch:check": "bunx madge --circular --extensions ts,tsx apps packages",
    "arch:deps": "bunx dependency-cruiser --validate .dependency-cruiser.js apps packages",
    "arch:all": "bun run arch:check && bun run arch:deps"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.3",
    "@turbo/gen": "2.8.10",
    "@types/node": "^25.3.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "diff": "^8.0.3",
    "turbo": "2.8.10",
    "typescript": "^5.9.3"
  },
  "packageManager": "bun@1.3.9",
  "workspaces": [
    "apps/*",
    "packages/*",
    "tooling/*"
  ],
  "resolutions": {
    "lodash": "^4.17.23",
    "lodash-es": "^4.17.23",
    "esbuild": "^0.27.3",
    "js-yaml": "^4.1.1",
    "diff": "^8.0.3",
    "tmp": "^0.2.5"
  },
  "dependencies": {
    "knip": "^5.83.1",
    "ts-pattern": "^5.9.0"
  }
}