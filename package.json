{
  "name": "@qbs-autonaim/root",
  "private": true,
  "engines": {
    "node": "^22.21.0",
    "bun": "1.3.6"
  },
  "scripts": {
    "build": "turbo run build",
    "clean": "git clean -xdf node_modules",
    "clean:workspaces": "turbo run clean",
    "auth:generate": "bun --filter @qbs-autonaim/auth generate",
    "db:push": "turbo -F @qbs-autonaim/db push",
    "db:studio": "turbo -F @qbs-autonaim/db studio",
    "db:generate-key": "bun --filter @qbs-autonaim/db generate-key",
    "db:migrate-workspaces": "bun --filter @qbs-autonaim/db migrate-workspaces",
    "dev": "turbo watch dev --continue",
    "dev:app": "turbo watch dev -F @qbs-autonaim/app...",
    "dev:all": "concurrently \"bun run tg:dev\" \"bun run jobs:dev\"",
    "jobs:dev": "bun --filter @qbs-autonaim/jobs dev",
    "jobs:inngest": "bun --filter @qbs-autonaim/jobs inngest",
    "jobs:inngest:dev": "npx cross-env INNGEST_SIGNING_KEY=dev-key INNGEST_EVENT_KEY=dev-event-key concurrently \"bun run jobs:dev\" \"npx --ignore-scripts=false inngest-cli@latest dev -u http://localhost:8000/api/inngest\"",
    "tg": "bun --filter @qbs-autonaim/tg-client start",
    "tg:dev": "bun --filter @qbs-autonaim/tg-client start:dev",
    "format": "biome format .",
    "format:fix": "biome format --write .",
    "hh:login": "bun --filter @qbs-autonaim/jobs hh:login",
    "hh:example": "bun --filter @qbs-autonaim/jobs hh:example",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "lint:ws": "bunx sherif@latest",
    "typecheck": "turbo run typecheck",
    "ui-add": "turbo run ui-add"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.12",
    "@turbo/gen": "2.7.5",
    "concurrently": "^9.2.1",
    "diff": "^8.0.3",
    "esbuild": "^0.27.2",
    "js-yaml": "^4.1.1",
    "lodash": "^4.17.23",
    "lodash-es": "^4.17.23",
    "tmp": "^0.2.5",
    "turbo": "2.7.5",
    "typescript": "5.9.3"
  },
  "packageManager": "bun@1.3.6",
  "workspaces": [
    "apps/*",
    "packages/*",
    "tooling/*"
  ],
  "resolutions": {
    "lodash": "^4.17.23",
    "lodash-es": "^4.17.23",
    "esbuild": "^0.27.2",
    "js-yaml": "^4.1.1",
    "diff": "^8.0.3",
    "tmp": "^0.2.5"
  }
}
