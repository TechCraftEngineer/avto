{
  "$schema": "https://biomejs.dev/schemas/2.4.3/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": false,
    "includes": [
      "**",
      "!**/.css",
      "!**/*.json",
      "!**/node_modules",
      "!**/.next",
      "!**/external",
      "!**/packages/inngest-realtime",
      "!**/packages/ui/src/**/*.tsx",
      "!**/apps/web/src/**/*.tsx",
      "!**/apps/web/src/**/*.ts",
      "!**/apps/docs/src/**/*.ts",
      "!**/packages/ui/src/**/*.ts",
      "!**/packages/ui/src/**/*.tsx",
      "!**/packages/ui/src/**/*.css",
      "!**/tooling/**/*",
      "!**/apps/app/**/*.css",
      "!**/apps/interview/**/*.css"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 80
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": {
        "noExplicitAny": "warn",
        "noAssignInExpressions": "off",
        "noArrayIndexKey": "warn"
      },
      "style": {
        "noNonNullAssertion": "warn",
        "useImportType": "error",
        "useTemplate": "warn"
      },
      "a11y": {
        "useSemanticElements": "warn"
      },
      "security": {
        "noDangerouslySetInnerHtml": "off"
      },
      "correctness": {
        "noUnusedVariables": {
          "level": "error"
        },
        "noChildrenProp": "off"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "trailingCommas": "all",
      "semicolons": "always"
    }
  },
  "css": {
    "parser": {
      "cssModules": false,
      "allowWrongLineComments": true,
      "tailwindDirectives": true
    }
  },
  "overrides": [
    {
      "includes": ["**/*.config.*", "**/env.ts"],
      "linter": {
        "enabled": false
      }
    },
    {
      "includes": ["**/*.css"],
      "css": {
        "parser": {
          "cssModules": false,
          "allowWrongLineComments": true,
          "tailwindDirectives": true
        }
      },
      "formatter": {
        "enabled": false
      },
      "linter": {
        "enabled": false
      }
    },
    {
      "includes": ["**/*.html"],
      "linter": {
        "enabled": false
      }
    },
    {
      "includes": [
        "**/*.test.ts",
        "**/*.test.tsx",
        "**/test-setup.ts",
        "**/__tests__/**"
      ],
      "linter": {
        "rules": {
          "suspicious": { "noExplicitAny": "off" },
          "style": { "noNonNullAssertion": "off" }
        }
      }
    }
  ]
}
