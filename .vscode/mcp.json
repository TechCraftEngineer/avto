{
  "servers": {
    "context7": {
      "type": "stdio",
      "command": "bunx",
      "args": [
        "-y",
        "@upstash/context7-mcp",
        "--api-key",
        "${MCP_API_KEY}"
      ],
      "env": {
        "MCP_API_KEY": "${MCP_API_KEY}"
      }
    },
    "postgres": {
      "type": "stdio",
      "command": "bunx",
      "args": [
        "@modelcontextprotocol/server-postgres",
        "${POSTGRES_URL}"
      ],
      "env": {
        "POSTGRES_URL": "${POSTGRES_URL}"
      }
    },
    "filesystem": {
      "type": "stdio",
      "command": "bunx",
      "args": [
        "@modelcontextprotocol/server-filesystem",
        "${MCP_ROOT_PATH}"
      ],
      "env": {
        "MCP_ROOT_PATH": "${MCP_ROOT_PATH}"
      }
    },
    "playwright": {
      "type": "stdio",
      "command": "bunx",
      "args": ["@playwright/mcp@latest"],
      "env": {}
    },
    "puppeteer": {
      "type": "stdio",
      "command": "bunx",
      "args": ["@puppeteer/mcp-server@latest"],
      "env": {}
    }
  },
  "inputs": []
}
