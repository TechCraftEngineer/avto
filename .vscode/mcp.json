{
  "servers": {
    "context7": {
      "type": "stdio",
      "command": "bunx",
      "args": [
        "-y",
        "@upstash/context7-mcp",
        "--api-key",
        "${MCP_API_KEY}"
      ],
      "env": {
        "MCP_API_KEY": "${MCP_API_KEY}"
      }
    },
    "postgres": {
      "type": "stdio",
      "command": "bunx",
      "args": [
        "@modelcontextprotocol/server-postgres",
        "${POSTGRES_URL}"
      ],
      "env": {
        "POSTGRES_URL": "${POSTGRES_URL}"
      }
    },
    "filesystem": {
      "type": "stdio",
      "command": "bunx",
      "args": [
        "@modelcontextprotocol/server-filesystem",
        "../../.."
      ]
    }
  },
  "inputs": []
}
