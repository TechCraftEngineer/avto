{
  "name": "@qbs-autonaim/db",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "default": "./src/index.ts"
    },
    "./client": {
      "default": "./src/client.ts"
    },
    "./client.ws": {
      "default": "./src/client.ws.ts"
    },
    "./client.cvscore": {
      "default": "./src/client.cvscore.ts"
    },
    "./schema": {
      "default": "./src/schema/index.ts"
    }
  },
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "dev": "tsc",
    "drop": "bun with-env bun src/scripts/drop-schema.ts",
    "reset-db": "bun with-env bun src/scripts/drop-schema.ts",
    "format": "biome format .",
    "lint": "biome lint .",
    "check": "biome check .",
    "push": "bun with-env drizzle-kit push",
    "studio": "bun with-env drizzle-kit studio",
    "migrate:create": "bun with-env drizzle-kit generate",
    "migrate": "bun with-env drizzle-kit migrate",
    "migrate:cvscore": "bun with-env drizzle-kit migrate --config drizzle.cvscore.config.ts",
    "push:cvscore": "bun with-env drizzle-kit push --config drizzle.cvscore.config.ts",
    "generate-key": "bun with-env bun src/scripts/generate-encryption-key.ts",
    "set-admin": "bun with-env bun src/scripts/set-admin-role.ts",
    "setup": "bun with-env bun src/scripts/setup-uuid-v7.ts",
    "seed": "bun with-env bun src/seed/preset-domains.ts",
    "update-counters": "bun with-env bun src/scripts/update-vacancy-counters.ts",
    "update-counter": "bun with-env bun src/scripts/update-vacancy-counter-by-id.ts",
    "check-vacancy": "bun with-env bun src/scripts/check-vacancy-data.ts",
    "migrate:candidates": "bun with-env bun src/scripts/migrate-candidates-to-global.ts",
    "backup:users-workspaces-orgs": "bun with-env bun src/scripts/backup-users-workspaces-orgs.ts",
    "restore:users-workspaces-orgs": "bun with-env bun src/scripts/restore-users-workspaces-orgs.ts",
    "typecheck": "npx tsc --noEmit",
    "with-env": "bun run --env-file ../../.env"
  },
  "dependencies": {
    "@qbs-autonaim/config": "workspace:*",
    "@qbs-autonaim/types": "workspace:*",
    "@qbs-autonaim/validators": "workspace:*",
    "@sindresorhus/slugify": "^3.0.0",
    "@vercel/postgres": "0.10.0",
    "drizzle-orm": "0.45.1",
    "drizzle-zod": "0.8.3",
    "nanoid": "^5.1.6",
    "pg": "^8.19.0",
    "validator": "^13.15.26",
    "ws": "^8.19.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@qbs-autonaim/tsconfig": "workspace:*",
    "@types/pg": "^8.18.0",
    "@types/validator": "^13.15.10",
    "@types/ws": "^8.18.1",
    "drizzle-kit": "^0.31.9",
    "postgres": "^3.4.8",
    "typescript": "5.9.3"
  }
}
