{
  "name": "@qbs-autonaim/jobs",
  "private": true,
  "type": "module",
  "version": "0.1.2",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./src/index.ts"
    },
    "./client": {
      "default": "./src/inngest/client.ts"
    },
    "./channels": {
      "default": "./src/inngest/channels/index.ts"
    },
    "./auth": {
      "default": "./src/services/auth/index.ts"
    },
    "./lib/ai-client": {
      "default": "./src/lib/ai-client.ts"
    },
    "./services/buffer": {
      "default": "./src/services/buffer/index.ts"
    },
    "./services/response": {
      "default": "./src/services/response/index.ts"
    },
    "./services/vacancy": {
      "default": "./src/services/vacancy/index.ts"
    },
    "./services/messaging": {
      "default": "./src/services/messaging/index.ts"
    },
    "./services/kwork": {
      "default": "./src/services/kwork/index.ts"
    }
  },
  "license": "MIT",
  "scripts": {
    "build": "tsdown",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "dev": "bun with-env bun run --watch src/inngest/server.ts",
    "inngest": "npx --ignore-scripts=false inngest-cli@latest dev -u http://localhost:8000/api/inngest",
    "inngest:dev": "bun inngest dev -u http://localhost:8000/api/inngest",
    "hh:parse": "bun with-env bun run src/hh-response-parser.ts",
    "hh:enrich": "bun with-env bun run src/hh-enrich-responses.ts",
    "fix:publications": "bun with-env bun run src/scripts/fix-vacancy-publications.ts",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "lint": "biome lint .",
    "typecheck": "tsc --noEmit",
    "with-env": "bun run --env-file ../../.env"
  },
  "dependencies": {
    "@ai-sdk/deepseek": "2.0.20",
    "@ai-sdk/openai": "3.0.29",
    "@bunworks/inngest-realtime": "workspace:*",
    "@qbs-autonaim/ai": "workspace:*",
    "@qbs-autonaim/config": "workspace:*",
    "@qbs-autonaim/db": "workspace:*",
    "@qbs-autonaim/emails": "workspace:*",
    "@qbs-autonaim/integration-clients": "workspace:*",
    "@qbs-autonaim/jobs-parsers": "workspace:*",
    "@qbs-autonaim/jobs-shared": "workspace:*",
    "@qbs-autonaim/lib": "workspace:*",
    "@qbs-autonaim/server-utils": "workspace:*",
    "@qbs-autonaim/shared": "workspace:*",
    "@qbs-autonaim/tg-client": "workspace:*",
    "@t3-oss/env-core": "0.13.10",
    "ai": "6.0.94",
    "axios": "1.13.5",
    "inngest": "3.52.1",
    "langfuse": "3.38.6",
    "sharp": "0.34.5",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@qbs-autonaim/tsconfig": "workspace:*",
    "@types/bun": "1.3.9",
    "@types/node": "25.2.3",
    "cross-env": "10.1.0",
    "inngest-cli": "1.17.1",
    "tsdown": "0.20.3",
    "typescript": "5.9.3"
  }
}
