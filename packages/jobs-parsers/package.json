    "@qbs-autonaim/server-utils": "workspace:*",
    "@qbs-autonaim/shared": "workspace:*",
    "axios": "1.13.6",
    "cheerio": "^1.2.0",
    "crawlee": "3.16.0",
    "puppeteer": "24.37.3",
    "puppeteer-extra": "3.3.6",
    "puppeteer-extra-plugin-stealth": "2.11.2",
    "sanitize-html": "^2.17.1",
    "string-strip-html": "13.5.3",
    "zod": "4.3.6"
