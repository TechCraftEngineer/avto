{
  "name": "@qbs-autonaim/lib",
  "version": "0.1.3",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./ai": {
      "types": "./dist/ai.d.mts",
      "default": "./dist/ai.mjs"
    },
    "./s3": {
      "types": "./dist/s3.d.mts",
      "default": "./dist/s3.mjs"
    },
    "./image": {
      "types": "./dist/image.d.mts",
      "default": "./dist/image.mjs"
    },
    "./instrumentation": {
      "types": "./dist/instrumentation.d.mts",
      "default": "./dist/instrumentation.mjs"
    },
    "./server": {
      "types": "./dist/server.d.mts",
      "default": "./dist/server.mjs"
    },
    "./utils": {
      "types": "./dist/utils.d.mts",
      "default": "./dist/utils.mjs"
    },
    "./errors": {
      "types": "./dist/errors.d.mts",
      "default": "./dist/errors.mjs"
    }
  },
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "license": "MIT",
  "scripts": {
    "build": "tsdown",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/deepseek": "2.0.20",
    "@ai-sdk/openai": "3.0.31",
    "@aws-sdk/client-s3": "3.996.0",
    "@aws-sdk/s3-request-presigner": "3.996.0",
    "@langfuse/otel": "4.6.1",
    "@langfuse/tracing": "4.6.1",
    "@openrouter/ai-sdk-provider": "2.2.3",
    "@opentelemetry/sdk-node": "0.212.0",
    "@qbs-autonaim/config": "workspace:*",
    "ai": "6.0.97",
    "langfuse": "3.38.6",
    "sharp": "0.34.5",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@qbs-autonaim/tsconfig": "workspace:*",
    "@types/node": "25.3.0",
    "tsdown": "0.20.3",
    "typescript": "5.9.3"
  }
}