{
  "name": "@qbs-autonaim/api",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./services": {
      "types": "./src/services/index.ts",
      "default": "./src/services/index.ts"
    },
    "./orpc": {
      "types": "./src/orpc.ts",
      "default": "./src/orpc.ts"
    },
    "./root-orpc": {
      "types": "./src/root-orpc.ts",
      "default": "./src/root-orpc.ts"
    }
  },
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "format": "biome format .",
    "lint": "biome lint .",
    "check": "biome check .",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "sync-gig-counts": "bun run --env-file ../../.env src/scripts/sync-gig-response-counts.ts"
  },
  "dependencies": {
    "@orpc/server": "1.13.6",
    "@qbs-autonaim/ai": "workspace:*",
    "@qbs-autonaim/auth": "workspace:*",
    "@qbs-autonaim/config": "workspace:*",
    "@qbs-autonaim/db": "workspace:*",
    "@qbs-autonaim/document-processor": "workspace:*",
    "@qbs-autonaim/emails": "workspace:*",
    "@qbs-autonaim/integration-clients": "workspace:*",
    "@qbs-autonaim/jobs": "workspace:*",
    "@qbs-autonaim/lib": "workspace:*",
    "@qbs-autonaim/server-utils": "workspace:*",
    "@qbs-autonaim/shared": "workspace:*",
    "@qbs-autonaim/tg-client": "workspace:*",
    "@qbs-autonaim/types": "workspace:*",
    "@qbs-autonaim/validators": "workspace:*",
    "@sindresorhus/slugify": "3.0.0",
    "random-word-slugs": "^0.1.7",
    "sanitize-html": "^2.17.1",
    "superjson": "2.2.6",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@qbs-autonaim/tsconfig": "workspace:*",
    "@types/sanitize-html": "^2.16.0",
    "fast-check": "^4.5.3",
    "glob": "^13.0.6",
    "tsdown": "0.20.3",
    "typescript": "5.9.3"
  }
}