{
  "name": "@qbs-autonaim/tg-client",
  "version": "0.1.2",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./sdk": {
      "types": "./dist/sdk/client.d.mts",
      "default": "./dist/sdk/client.mjs"
    },
    "./handlers/message-handler": {
      "types": "./src/handlers/message-handler.ts",
      "default": "./src/handlers/message-handler.ts"
    }
  },
  "license": "MIT",
  "scripts": {
    "build": "tsdown && tsc --emitDeclarationOnly",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "start:dev": "tsdown --watch",
    "start": "bun run src/api/index.ts",
    "dev": "bun run --env-file ../../.env --watch src/api/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@mtcute/bun": "0.28.1",
    "@mtcute/core": "0.28.1",
    "@mtcute/dispatcher": "0.28.1",
    "@qbs-autonaim/config": "workspace:*",
    "@qbs-autonaim/db": "workspace:*",
    "@qbs-autonaim/lib": "workspace:*",
    "@qbs-autonaim/ai": "workspace:*",
    "@qbs-autonaim/shared": "workspace:*",
    "@qbs-autonaim/server-utils": "workspace:*",
    "file-type": "21.3.0",
    "hono": "4.12.3",
    "long": "^5.3.2",
    "mime-types": "3.0.2",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@qbs-autonaim/tsconfig": "workspace:*",
    "@types/bun": "1.3.9",
    "@types/mime-types": "^3.0.1",
    "@types/node": "25.3.3",
    "tsdown": "0.20.3",
    "typescript": "5.9.3"
  }
}