{
  "name": "recruitment-assistant-extension",
  "version": "1.0.1",
  "private": true,
  "description": "Chrome extension for recruitment automation",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:local": "EXTENSION_API_URL=http://localhost:3000 vite",
    "build": "bun run generate-icons && tsc && vite build && bun run generate-icons:dist",
    "build:local": "EXTENSION_API_URL=http://localhost:3000 EXTENSION_API_BASE=http://localhost:3002 bun run build",
    "generate-icons": "bun run scripts/generate-icons.ts",
    "generate-icons:dist": "bun run scripts/generate-icons.ts dist",
    "preview": "vite preview",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@qbs-autonaim/tsconfig": "workspace:*",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/bun": "^1.3.9",
    "@types/chrome": "^0.1.36",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.1.4",
    "axe-core": "^4.11.1",
    "fast-check": "4.5.3",
    "happy-dom": "^20.6.1",
    "sharp": "^0.34.5",
    "typescript": "^5.9.3",
    "vite": "7.3.1",
    "vite-plugin-web-extension": "^4.5.0"
  }
}
