{
  "manifest_version": 3,
  "name": "Recruitment Assistant",
  "version": "1.0.0",
  "description": "Расширение для автоматизации работы рекрутеров с профилями кандидатов на LinkedIn и HeadHunter",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://linkedin.com/*",
    "https://hh.ru/*",
    "https://www.hh.ru/*"
  ],
  "background": {
    "service_worker": "src/background/service-worker.ts"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/in/*",
        "https://linkedin.com/in/*",
        "https://hh.ru/resume/*",
        "https://www.hh.ru/resume/*"
      ],
      "js": ["src/content/content-script.ts"],
      "css": ["src/content/content-styles.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Recruitment Assistant"
  },
  "options_page": "src/options/options.html",
  "web_accessible_resources": [
    {
      "resources": ["content/*.css", "icons/*"],
      "matches": [
        "https://www.linkedin.com/*",
        "https://linkedin.com/*",
        "https://hh.ru/*",
        "https://www.hh.ru/*"
      ]
    }
  ]
}
