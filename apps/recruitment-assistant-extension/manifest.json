{
  "manifest_version": 3,
  "name": "Recruitment Assistant",
  "version": "1.0.4",
  "key": "",
  "description": "Расширение для автоматизации работы рекрутеров с профилями кандидатов на LinkedIn и HeadHunter",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage", "activeTab", "tabs", "scripting"],
  "content_security_policy":{"extension_pages":"script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"},"host_permissions": [
    "https://www.linkedin.com/*",
    "https://linkedin.com/*",
    "https://hh.ru/*",
    "https://www.hh.ru/*",
    "https://*.hh.ru/*",
    "https://app.avtonaim.qbsoft.ru/*",
    "http://localhost:3000/*"
  ],
  "background": {
    "service_worker": "src/background/service-worker.ts"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/in/*",
        "https://linkedin.com/in/*",
        "https://hh.ru/resume/*",
        "https://www.hh.ru/resume/*",
        "*://*.hh.ru/*"
      ],
      "js": ["src/content/content-script.tsx"],
      "css": ["src/content/content-styles.css"],
      "run_at": "document_idle"
    },
  {
    "matches": [
      "https://hh.ru/employer/*",
      "https://www.hh.ru/employer/*",
      "https://employer.hh.ru/*",
      "*://*.hh.ru/*"
    ],
    "js": ["src/content/hh-employer-content-script.ts"],
    "run_at": "document_idle"
  }
  ],
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Помощник рекрутера"
  },
  "web_accessible_resources": [
    {
      "resources": ["content/*.css", "icons/*"],
      "matches": [
        "https://www.linkedin.com/*",
        "https://linkedin.com/*"
      ]
    },
    {
      "resources": ["src/callback.html"],
      "matches": [
        "https://app.avtonaim.qbsoft.ru/*",
        "http://localhost:3000/*"
      ]
    },
    {
      "resources": ["src/injected/fetch-page-context.js"],
      "matches": [
        "https://hh.ru/*",
        "https://www.hh.ru/*",
        "https://employer.hh.ru/*",
        "*://*.hh.ru/*"

      ]
    }
  ]
}
