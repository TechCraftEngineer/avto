{
  "name": "@qbs-autonaim/webhooks",
  "private": true,
  "type": "module",
  "version": "0.1.0",
  "scripts": {
    "dev": "bun with-env bun run --hot src/index.ts",
    "start": "bun with-env bun run src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:unit": "bun test --test-name-pattern='Unit Tests'",
    "test:property": "bun test --test-name-pattern='Property-Based Tests'",
    "with-env": "bun run --env-file ../../.env"
  },
  "dependencies": {
    "@qbs-autonaim/db": "workspace:*",
    "@qbs-autonaim/validators": "workspace:*",
    "hono": "4.12.5",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@qbs-autonaim/config": "workspace:*",
    "@qbs-autonaim/tsconfig": "workspace:*",
    "@types/bun": "1.3.10",
    "fast-check": "4.5.3",
    "typescript": "5.9.3"
  }
}