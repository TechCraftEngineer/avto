{
  "name": "@qbs-autonaim/app-server",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc -b",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
    "dev": "bun run --hot src/index.ts",
    "start": "bun run dist/index.mjs"
  },
  "dependencies": {
    "@qbs-autonaim/api": "workspace:*",
    "@qbs-autonaim/auth": "workspace:*",
    "@qbs-autonaim/config": "workspace:*",
    "@qbs-autonaim/db": "workspace:*",
    "@qbs-autonaim/emails": "workspace:*",
    "@qbs-autonaim/lib": "workspace:*",
    "@qbs-autonaim/server-utils": "workspace:*",
    "better-auth": "1.4.18",
    "hono": "^4.12.0",
    "superjson": "2.2.6",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@qbs-autonaim/tsconfig": "workspace:*",
    "@types/bun": "^1.2.15",
    "tsdown": "^0.16.5",
    "typescript": "5.9.3"
  }
}
