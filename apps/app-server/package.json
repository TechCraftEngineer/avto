{
  "name": "@qbs-autonaim/app-server",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc -b",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
    "dev": "bun with-env bun run --hot src/index.ts",
    "start": "bun run dist/index.mjs",
    "with-env": "bun run --env-file ../../.env"

  },
  "dependencies": {
    "@orpc/server": "1.13.6",
    "@qbs-autonaim/api": "workspace:*",
    "@qbs-autonaim/auth": "workspace:*",
    "@qbs-autonaim/config": "workspace:*",
    "@qbs-autonaim/db": "workspace:*",
    "@qbs-autonaim/emails": "workspace:*",
    "@qbs-autonaim/lib": "workspace:*",
    "@qbs-autonaim/server-utils": "workspace:*",
    "better-auth": "1.5.2",
    "hono": "4.12.3",
    "superjson": "2.2.6",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@qbs-autonaim/tsconfig": "workspace:*",
    "@types/bun": "^1.3.9",
    "tsdown": "0.20.3",
    "typescript": "5.9.3"
  }
}